{
  "name": "software-testing-assignment",
  "version": "1.0.0",
  "description": "This is a project template for students participating in Software Testing course at LAB University of Applied Sciences.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "mocha",
    "coverage": "npx nyc mocha",
    "coveralls": "npx nyc report --reporter=text-lcov | npx coveralls"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "chai": "^6.2.2",
    "coveralls": "^3.1.1",
    "jest": "^30.3.0",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "proxyquire": "^2.1.3"
  },
  "nyc": {
    "all": true,
    "extension": [".js"],
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "include":
      [
        "src/**/*.js"
      ],
    "exclude": [
      "test/**",
      "src/.internal/**"
    ]
  },
  "keywords": []
}
